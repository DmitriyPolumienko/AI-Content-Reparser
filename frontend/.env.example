NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for Auth callback & Stripe redirects (set to your production URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase service-role key — NEVER expose to the browser; used only in API routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Stripe Price IDs (replace with real IDs from your Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_pro_placeholder
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_placeholder
