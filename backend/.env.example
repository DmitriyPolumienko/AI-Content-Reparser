OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
# Optional: regex pattern to allow dynamic preview URLs (e.g. Vercel preview deployments)
# Default matches any *.vercel.app origin; set to empty string to disable
ALLOWED_ORIGINS_REGEX=https://.*\.vercel\.app$

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-secret-key

# Webshare Proxy Configuration (Optional)
# Format: IP:PORT:USERNAME:PASSWORD,IP:PORT:USERNAME:PASSWORD,...
# Leave empty for local development (no proxy needed)
WEBSHARE_PROXY_LIST=
