OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
# Optional: regex pattern to allow dynamic preview URLs (e.g. Vercel preview deployments)
# Default matches any *.vercel.app origin; set to empty string to disable
ALLOWED_ORIGINS_REGEX=https://.*\.vercel\.app$

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-secret-key

# Webshare Rotating Proxy Configuration (Optional)
# Generates session IDs dynamically: <username>-1 .. <username>-<max_session_id>
# Leave empty to disable proxy (local development)
WEBSHARE_PROXY_HOST=p.webshare.io
WEBSHARE_PROXY_PORT=80
WEBSHARE_PROXY_USERNAME=your-webshare-username
WEBSHARE_PROXY_PASSWORD=your-webshare-password
WEBSHARE_MAX_SESSION_ID=215084

# Legacy static proxy list (deprecated – use rotating proxy vars above instead)
# Format: IP:PORT:USERNAME:PASSWORD,IP:PORT:USERNAME:PASSWORD,...
WEBSHARE_PROXY_LIST=

# Redis Configuration (Optional – enables background queue for high-traffic scenarios)
# Providers: Upstash (free tier), Redis Labs, Render Redis
REDIS_URL=redis://localhost:6379
